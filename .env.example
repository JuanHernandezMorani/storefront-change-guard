# Copy this file to .env. Never commit the resulting .env file.

# Repository paths. Relative paths are resolved from the project root.
SCG_REPOSITORY_PATH=demo-storefront
SCG_ARTIFACTS_DIR=artifacts
SCG_POLICY_PATH=policies/storefront_policy.yaml
SCG_WORKTREE_ROOT=.worktrees

# Local-first model configuration. This remains optional until Phase 03.
# Example llama.cpp server endpoint: http://127.0.0.1:8081/v1
SCG_MODEL_BASE_URL=http://127.0.0.1:8081/v1
SCG_MODEL_NAME=replace-with-local-model-name
SCG_MODEL_API_KEY=not-required-for-local-endpoint
SCG_MODEL_TIMEOUT_SECONDS=90

# Runtime controls. Remote execution and arbitrary model-generated shell commands
# must remain disabled by default.
SCG_ALLOW_REMOTE_MODEL=false
SCG_ALLOW_MODEL_SHELL_COMMANDS=false
SCG_MAX_CONTEXT_CHARS=24000
