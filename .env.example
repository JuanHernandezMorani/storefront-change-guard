# Copy this file to .env. Never commit the resulting .env file.

# Repository paths. Relative paths are resolved from the project root.
SCG_REPOSITORY_PATH=demo-storefront
SCG_ARTIFACTS_DIR=artifacts
SCG_POLICY_PATH=policies/storefront_policy.yaml
SCG_WORKTREE_ROOT=.worktrees

# Phase 03: Local model runtime configuration
# Path to llama-cli executable (required, no auto-discovery)
# Uses Test 1 profile with --jinja, -st, -f, stdin=DEVNULL
STORE_FRONT_GUARD_LLAMA_EXECUTABLE=C:\ruta\a\llama.cpp\build\bin\Release\llama-cli.exe
# Path to model file (defaults to agent_solution/model/Qwen3.5-4B-UD-Q4_K_XL.gguf)
STORE_FRONT_GUARD_MODEL_PATH=C:\ruta\al\modelo\Qwen3.5-4B-UD-Q4_K_XL.gguf
# State directory for cache and session storage
STORE_FRONT_GUARD_STATE_DIR=.runtime\state
# Model timeout in seconds (default: 120)
STORE_FRONT_GUARD_MODEL_TIMEOUT=120
# Number of threads for model execution (default: 4)
STORE_FRONT_GUARD_MODEL_THREADS=4

# Runtime controls. Remote execution and arbitrary model-generated shell commands
# must remain disabled by default.
SCG_ALLOW_REMOTE_MODEL=false
SCG_ALLOW_MODEL_SHELL_COMMANDS=false
SCG_MAX_CONTEXT_CHARS=24000
